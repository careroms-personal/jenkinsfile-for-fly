def buildStepSelected = BUILD_STEP_SELECT.toLowerCase().replace(" ", "")
def gitRepo = ""
def dockerRegistry = ""
def helmName = ""
def projectConfig

node("general-job") {
  container("ubuntu") {
    stage("Checkout pipeline project") {
      checkout scm
    }

    stage("Read yaml config") {
      projectConfig = readYaml(file: "docker-builder/pipeline-config.yaml")
    }

    stage("Select config") {
      def selected = projectConfig.projectConfigs[SELECT_STUPID_PROJECT]

      gitRepo = selected.gitRepo
      dockerRegistry = selected.dockerRegistry
      helmName = selected.helmName
    }
  }
}

node("image-builder") {
  container("kaniko"){
    stage("Build image") {
      if(buildStepSelected.contains("builddocker")) {
        sh """
          /kaniko/executor \
            --context=git://github.com/${gitRepo}#refs/heads/main \
            --dockerfile=Dockerfile \
            --destination=careromspersonal/${dockerRegistry}:latest
        """
      } else {
        echo "Skip docker build step."
      }
    }
  }
}

node("helm-deploy") {
  container("helm") {
    if(buildStepSelected.contains("helmdeploy")) {
      stage("Checkout Project helm file") {
        checkout(
          scmGit(
            branches: [[name: '*/main']], 
            extensions: [
              cloneOption(depth: 1, noTags: false, reference: '', shallow: true), 
              sparseCheckout([[path: 'helm']])], 
            userRemoteConfigs: [[url: "https://github.com/${gitRepo}"]]))
      }

      stage("Check file") {
        sh "ls"
      }

      stage("Helm deploy") {
        sh "helm upgrade ${helmName} --install --namespace default ./helm --debug"
      }
    } else {
      echo "Skip Helm deploy step."
    }
  }
}